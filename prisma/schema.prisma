generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  name      String   @map("nome")
  username  String   @unique @map("usuario")
  password  String?  @map("senha")
  email     String?  @unique @map("email")
  googleId  String?  @unique @map("google_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expensesPaid          Expense[]            @relation("ExpensePayer")
  expenseParticipations ExpenseParticipant[]
  shoppingItemsAdded    ShoppingItem[]
  memberships           GroupMember[]
  settlementsFrom       Settlement[]         @relation("SettlementFrom")
  settlementsTo         Settlement[]         @relation("SettlementTo")
  settlementsCreated    Settlement[]         @relation("SettlementCreatedBy")
  auditEntries          AuditLog[]           @relation("AuditActor")

  @@index([publicId])
}

model Group {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  name        String   @map("nome")
  description String?  @map("descricao")
  joinCode    String?  @unique @map("codigo_convite")
  currency    String   @default("BRL") @map("moeda")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses      Expense[]
  shoppingItems ShoppingItem[]
  members       GroupMember[]
  settlements    Settlement[]
  auditLogs      AuditLog[]
  categories     Category[]
  platforms      Platform[]
  paymentMethods PaymentMethod[]

  @@index([publicId])
}

enum GroupRole {
  ADMIN
  MEMBER
}

model GroupMember {
  id         Int       @id @default(autoincrement())
  userId     Int
  groupId    Int
  role       GroupRole @default(MEMBER)
  colorIndex Int       @default(0) @map("indice_cor")
  createdAt  DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("membro_grupo")
}

// Custom expense categories a house can create. The 10 system defaults (lib/categories) are NOT
// stored here — they're i18n keys. Expense.category holds either a system key or a custom name.
model Category {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  groupId   Int      @map("grupo_id")
  name      String   @map("nome")
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
  @@map("categoria_casa")
}

// A house's custom platforms (system defaults from lib/platforms are i18n keys, not stored).
// Like Category: Expense.platforms[] holds a system key or a custom name (no FK).
model Platform {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  groupId   Int      @map("grupo_id")
  name      String   @map("nome")
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
  @@map("plataforma")
}

// A house's custom payment methods (system defaults from lib/payment-methods are i18n keys).
model PaymentMethod {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  groupId   Int      @map("grupo_id")
  name      String   @map("nome")
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
  @@map("forma_pagamento_casa")
}

model Expense {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  groupId     Int
  payerId     Int
  platformId  Int?     @map("plataforma_id") // legacy single (vestigial; replaced by platforms[])
  platformIds Int[]    @default([]) @map("plataforma_ids") // vestigial intermediate (replaced by platforms[])
  description String   @map("descricao")
  notes       String?  @map("observacao")
  category    String?  @map("categoria") // legacy single (vestigial; replaced by categories[])
  // The three tag dimensions: each entry is a system-default key OR a house's custom name.
  categories     String[] @default([]) @map("categorias")
  platforms      String[] @default([]) @map("plataformas")
  paymentMethods String[] @default([]) @map("formas_pagamento")
  amount      Decimal  @db.Decimal(10, 2) @map("valor")
  date        DateTime @default(now()) @map("data")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                 @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Cascade)
  participants ExpenseParticipant[]

  @@index([publicId])
  @@index([groupId, date])
}

model ExpenseParticipant {
  id        Int     @id @default(autoincrement())
  expenseId Int
  userId    Int
  amount    Decimal @db.Decimal(10, 2) @map("valor")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model ShoppingItem {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  groupId     Int
  name        String   @map("nome")
  isPurchased Boolean  @default(false) @map("comprado")
  createdAt   DateTime @default(now()) @map("criado_em")
  addedById   Int?     @map("adicionado_por")

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addedBy User? @relation(fields: [addedById], references: [id])

  @@index([publicId])
  @@index([groupId, isPurchased])
  @@map("item_compra")
}

// A recorded payment from one member to another that clears/reduces a balance.
// Folded into balance computation as a signed transfer (from pays to).
model Settlement {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  groupId     Int
  fromUserId  Int      @map("de_usuario")
  toUserId    Int      @map("para_usuario")
  amount      Decimal  @db.Decimal(10, 2) @map("valor")
  note        String?  @map("observacao")
  date        DateTime @default(now()) @map("data")
  createdById Int?     @map("criado_por")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser  User  @relation("SettlementFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser    User  @relation("SettlementTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdBy User? @relation("SettlementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([publicId])
  @@index([groupId, date])
  @@map("acerto")
}

// Append-only activity/change log for the house (expenses, settlements, shopping, house/members).
model AuditLog {
  id         Int      @id @default(autoincrement())
  groupId    Int
  actorId    Int?     @map("autor")
  entityType String   @map("tipo_entidade")
  entityId   String?  @map("entidade_id")
  action     String   @map("acao")
  summary    String   @map("resumo")
  changes    Json?    @map("alteracoes")
  createdAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt])
  @@map("registro_auditoria")
}

// Envers-style automatic revision trail: one row per create/update/delete of any audited entity,
// with a full before/after JSON snapshot + who + which house. Standalone (NO foreign keys) so the
// audit history survives even after the entity, its group, or the actor is deleted.
model EntityRevision {
  id         Int      @id @default(autoincrement())
  entityType String   @map("tipo_entidade") // Prisma model name (Expense, Settlement, …)
  entityId   String   @map("entidade_id")   // stringified primary key of the affected row
  groupId    Int?     @map("grupo_id")       // tenant, when the entity carries one (for scoping)
  action     String   @map("acao")           // CREATE | UPDATE | DELETE
  actorId    Int?     @map("autor")           // session user that triggered the write
  before     Json?    @map("antes")           // full row before (null for CREATE)
  after      Json?    @map("depois")          // full row after (null for DELETE)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([groupId, createdAt])
  @@map("revisao_entidade")
}
