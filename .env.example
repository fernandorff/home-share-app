# Postgres (Neon). Use a string pooled (-pooler) em serverless.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Segredo do JWT (obrigatório em produção)
JWT_SECRET="troque-por-um-segredo-forte"
# Origins permitidos no CORS, separados por vírgula. Vazio = '*'
ALLOWED_ORIGINS=""
# Google OAuth (login com Google). Vazio = botão desabilitado.
# Redirect URI: <origin>/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
