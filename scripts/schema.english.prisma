generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  name      String
  username  String   @unique
  password  String?
  email     String?  @unique
  // True only when this address was attested by Google (or a trusted one-time backfill), never by
  // a plain self-service PATCH — the OAuth auto-link-by-email flow refuses to trust an unverified one.
  emailVerified Boolean @default(false)
  googleId  String?  @unique
  // Bumped on logout and on password change to invalidate every previously issued JWT for this
  // user at once (JWTs are otherwise stateless and would keep working until they expire on their
  // own) — the token carries the version it was signed with; a mismatch means it was revoked.
  sessionVersion Int @default(0)
  // Set on self-service account deletion (BL-23). The row is never hard-deleted — Expense/
  // Settlement/etc. FKs point straight at User.id and must survive so other members' history
  // stays intact. name/username/email/password/googleId are scrubbed at the same time; login is
  // naturally impossible afterwards (password and googleId are both null).
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expensesPaid          Expense[]            @relation("ExpensePayer")
  expenseParticipations ExpenseParticipant[]
  shoppingItemsAdded    ShoppingItem[]
  memberships           GroupMember[]
  settlementsFrom       Settlement[]         @relation("SettlementFrom")
  settlementsTo         Settlement[]         @relation("SettlementTo")
  settlementsCreated    Settlement[]         @relation("SettlementCreatedBy")
  auditEntries          AuditLog[]           @relation("AuditActor")

  @@index([publicId])
}

model Group {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  name        String
  description String?
  joinCode    String?  @unique
  currency    String   @default("BRL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses      Expense[]
  shoppingItems ShoppingItem[]
  members       GroupMember[]
  settlements    Settlement[]
  auditLogs      AuditLog[]
  categories     Category[]
  platforms      Platform[]
  paymentMethods PaymentMethod[]

  @@index([publicId])
}

enum GroupRole {
  ADMIN
  MEMBER
}

model GroupMember {
  id         Int       @id @default(autoincrement())
  userId     Int
  groupId    Int
  role       GroupRole @default(MEMBER)
  colorIndex Int       @default(0)
  createdAt  DateTime  @default(now())
  // Soft-remove (BL-16): set on leave/kick, cleared on rejoin. The row is never deleted so
  // Expense/Settlement history keeps its real name+color; only ACTIVE (leftAt null) members are
  // offered as payer/participant for NEW expenses and count toward "who's in this house".
  leftAt     DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

// Custom expense categories a house can create. The 10 system defaults (lib/categories) are NOT
// stored here — they're i18n keys. Expense.category holds either a system key or a custom name.
model Category {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  groupId   Int
  name      String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
}

// A house's custom platforms (system defaults from lib/platforms are i18n keys, not stored).
// Like Category: Expense.platforms[] holds a system key or a custom name (no FK).
model Platform {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  groupId   Int
  name      String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
}

// A house's custom payment methods (system defaults from lib/payment-methods are i18n keys).
model PaymentMethod {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @db.Uuid
  groupId   Int
  name      String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  groupId     Int
  payerId     Int
  platformId  Int? // legacy single (vestigial; replaced by platforms[])
  platformIds Int[]    @default([]) // vestigial intermediate (replaced by platforms[])
  description String
  notes       String?
  category    String? // legacy single (vestigial; replaced by categories[])
  // The three tag dimensions: each entry is a system-default key OR a house's custom name.
  categories     String[] @default([])
  platforms      String[] @default([])
  paymentMethods String[] @default([])
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                 @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Cascade)
  participants ExpenseParticipant[]

  @@index([publicId])
  @@index([groupId, date])
}

model ExpenseParticipant {
  id        Int     @id @default(autoincrement())
  expenseId Int
  userId    Int
  amount    Decimal @db.Decimal(10, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model ShoppingItem {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  groupId     Int
  name        String
  isPurchased Boolean  @default(false)
  createdAt   DateTime @default(now())
  addedById   Int?

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addedBy User? @relation(fields: [addedById], references: [id])

  @@index([publicId])
  @@index([groupId, isPurchased])
}

// A recorded payment from one member to another that clears/reduces a balance.
// Folded into balance computation as a signed transfer (from pays to).
model Settlement {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @db.Uuid
  groupId     Int
  fromUserId  Int
  toUserId    Int
  amount      Decimal  @db.Decimal(10, 2)
  note        String?
  date        DateTime @default(now())
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser  User  @relation("SettlementFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser    User  @relation("SettlementTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdBy User? @relation("SettlementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([publicId])
  @@index([groupId, date])
}

// Append-only activity/change log for the house (expenses, settlements, shopping, house/members).
model AuditLog {
  id         Int      @id @default(autoincrement())
  groupId    Int
  actorId    Int?
  entityType String
  entityId   String?
  action     String
  summary    String
  changes    Json?
  createdAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt])
}

// Envers-style automatic revision trail: one row per create/update/delete of any audited entity,
// with a full before/after JSON snapshot + who + which house. Standalone (NO foreign keys) so the
// audit history survives even after the entity, its group, or the actor is deleted.
model EntityRevision {
  id         Int      @id @default(autoincrement())
  entityType String // Prisma model name (Expense, Settlement, …)
  entityId   String   // stringified primary key of the affected row
  groupId    Int?       // tenant, when the entity carries one (for scoping)
  action     String           // CREATE | UPDATE | DELETE
  actorId    Int?           // session user that triggered the write
  before     Json?           // full row before (null for CREATE)
  after      Json?          // full row after (null for DELETE)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([groupId, createdAt])
}
